# ─────────────────────────────────────────────────────────────
# FormBot — Environment Variables
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────

# API key used by the frontend and all API clients.
# Generate a secure key: openssl rand -hex 32
API_KEY=CHANGE_ME_TO_A_SECURE_RANDOM_KEY

# PostgreSQL password for the 'formbot' user.
# Generate one: openssl rand -hex 16
DB_PASSWORD=CHANGE_ME_TO_A_SECURE_DB_PASSWORD

# ── REQUIRED IN PRODUCTION ────────────────────────────────────

# Comma-separated list of allowed frontend origins.
# Example: ALLOWED_ORIGINS=https://formbot.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173

# Set to 'production' to disable /docs Swagger UI.
ENV=development

# ── OPTIONAL ─────────────────────────────────────────────────

# Maximum number of concurrent Playwright automation jobs.
# Each browser uses ~200 MB RAM. Default: 5
MAX_CONCURRENT_JOBS=5

# Frontend API base URL (leave blank when using nginx proxy).
# Only set this if running frontend separately from nginx.
VITE_API_URL=
